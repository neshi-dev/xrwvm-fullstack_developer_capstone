# =============================================================================
# Best Cars Dealership — Environment Variable Template
# =============================================================================
# Copy this file to server/.env and fill in the values for your environment.
#
#   cp .env.example server/.env
#
# NEVER commit server/.env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------

# Secret key used for cryptographic signing (sessions, CSRF tokens, etc.).
# Generate a strong key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-me-with-a-strong-random-key

# Set to False in any non-development environment.
DJANGO_DEBUG=True

# -----------------------------------------------------------------------------
# Microservice URLs
# -----------------------------------------------------------------------------

# URL of the Node.js dealership/review Express API.
# Default for local development:
backend_url=http://localhost:3030

# URL of the Flask NLTK sentiment analyser microservice.
# Default for local development:
sentiment_analyzer_url=http://localhost:5050/

# -----------------------------------------------------------------------------
# Node.js Express API (server/database)
# -----------------------------------------------------------------------------

# Comma-separated list of origins allowed to call the Express API.
# Leave empty to allow all origins (development only).
# Example: ALLOWED_ORIGINS=http://localhost:8000,https://yourdomain.com
ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# Flask Sentiment Service (server/djangoapp/microservices)
# -----------------------------------------------------------------------------

# Set to True only in local development. Never True in production.
FLASK_DEBUG=False
